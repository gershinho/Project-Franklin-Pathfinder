#!/bin/sh
# Block accidental commits of local env files (keys stay on your machine only).

blocked=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^\.env(\.|$)' | grep -v '^\.env\.example$' || true)

if [ -n "$blocked" ]; then
  echo "Blocked: refusing to commit local env files:"
  echo "$blocked" | sed 's/^/  /'
  echo ""
  echo "Copy values to .env locally; only .env.example belongs in git."
  exit 1
fi
